{
  "audioMode": "cdn_soundfont",
  "cdnSoundfont": {
    "url": "https://gleitz.github.io/midi-js-soundfonts/FluidR3_GM/harpsichord-mp3.js",
    "global": "MIDI.Soundfont.harpsichord",
    "notation": "flat_keys",
    "rangeHint": "C0-C8"
  },
  "localSampleSets": {
    "french": {
      "displayName": "French (local)",
      "baseUrl": "./sounds/french/",
      "notes": {}
    },
    "italian": {
      "displayName": "Italian (local)",
      "baseUrl": "./sounds/italian/",
      "notes": {}
    }
  },
  "defaultUi": {
    "registration": "s8",
    "octaveShift": 0,
    "audioSource": "cdn",
    "preloadNotes": ["C4", "E4", "G4", "C5"]
  }
}
